{
  "name": "mobile-app-ux-auditor-skill",
  "version": "0.2.0",
  "description": "Agent Skill for auditing and improving mobile app UI/UX flows across Flutter, React Native, iOS, and Android.",
  "license": "MIT",
  "author": {
    "name": "Ajnas NB",
    "email": "ajnasnb@gmail.com"
  },
  "type": "commonjs",
  "scripts": {
    "test": "node --test",
    "audit": "npm audit --audit-level=high",
    "pack:check": "npm pack --dry-run --ignore-scripts",
    "release:check": "npm test && npm run audit && npm run pack:check",
    "prepublishOnly": "npm run release:check"
  },
  "bin": {
    "mobile-app-ux-auditor": "bin/install.js",
    "mobile-app-ux-auditor-skill": "bin/install.js"
  },
  "files": [
    "SKILL.md",
    "agents/",
    "references/",
    "scripts/",
    "skills/",
    "bin/",
    ".codex-plugin/",
    ".claude-plugin/",
    "CHANGELOG.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agent-skill",
    "claude-code",
    "codex",
    "ux",
    "ui",
    "mobile",
    "flutter",
    "react-native",
    "ios",
    "android",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AjnasNB/mobile-app-ux-auditor-skill.git"
  },
  "bugs": {
    "url": "https://github.com/AjnasNB/mobile-app-ux-auditor-skill/issues"
  },
  "homepage": "https://github.com/AjnasNB/mobile-app-ux-auditor-skill#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || ^26.0.0"
  }
}
